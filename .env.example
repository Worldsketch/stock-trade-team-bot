KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NUMBER=your_account_number
KIS_ACCOUNT_CODE=01
KIS_ENABLE_DAYTIME_TRADING=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
GEMINI_API_KEY=your_gemini_api_key
# Auth (우선순위: ADMIN_USERS_JSON > ADMIN_USERS > ADMIN_USERNAME/ADMIN_PASSWORD)
# ADMIN_USERS 예시: manchi:001122,dooboo:001122,jack:001122
ADMIN_USERS=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
# Security: reverse proxy(Nginx) 사용 시 로컬 바인딩 권장
APP_HOST=127.0.0.1
APP_PORT=8000
# Optional: manual sell 예상 순수령/손익 계산용(비율, 예: 0.0025 = 0.25%)
SELL_FEE_RATE=0
SELL_TAX_RATE=0
# Optional: 전략 기본 모드(auto/aggressive/defensive)
DEFAULT_STRATEGY_MODE=auto
# Optional: auto 모드 전환 기준
AUTO_DEFENSIVE_CASH_RATIO=0.45
AUTO_DEFENSIVE_SMA_COUNT=2
# Optional: 모드별 매수 비율 튜닝
STRATEGY_AGGRESSIVE_BASE=0.001
STRATEGY_AGGRESSIVE_W2=0.018
STRATEGY_AGGRESSIVE_W4=0.03
STRATEGY_AGGRESSIVE_W8=0.042
STRATEGY_DEFENSIVE_BASE=0.0005
STRATEGY_DEFENSIVE_W2=0.008
STRATEGY_DEFENSIVE_W4=0.014
STRATEGY_DEFENSIVE_W8=0.02
# Optional: 일일 자동매수 총량 상한(총자산 대비 비율, 예: 0.12 = 12%)
DAILY_BUY_CAP_RATIO=0.12
# Optional: 현금 비중 기반 매수 제어
CASH_FLOOR_HARD_RATIO=0.30
CASH_FLOOR_SOFT_RATIO=0.45
BUY_CAP_HIGH_CASH_TRIGGER=0.55
BUY_CAP_RATIO_HIGH_CASH=0.08
BUY_CAP_RATIO_MID_CASH=0.04
BUY_CAP_RATIO_LOW_CASH=0.02
# Optional: 매수 우선순위 목표비중 (비워두면 동일비중 자동 적용)
TARGET_WEIGHTS=
# Optional: 자동 부분익절 (+수익률 구간별 부분매도)
AUTO_TAKE_PROFIT_ENABLED=true
AUTO_TAKE_PROFIT_LEVELS=12,20,30
AUTO_TAKE_PROFIT_SELL_PCTS=0.15,0.20,0.25
AUTO_TAKE_PROFIT_COOLDOWN_SEC=300

# Server Deploy
DEPLOY_HOST=your_server_ip
DEPLOY_USER=root
DEPLOY_PASSWORD=your_server_password
DEPLOY_PATH=/root/stock-trade-bot-v1
